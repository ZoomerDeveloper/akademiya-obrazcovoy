# SMS Auth Service — конфигурация
# Скопируйте в .env и заполните значения

# ─── Порт сервиса ────────────────────────────────────
PORT=3002

# ─── sms.ru ──────────────────────────────────────────
# API-ключ из личного кабинета: https://sms.ru/api/
SMSRU_API_ID=ВСТАВЬТЕ_ВАШЕ_API_ID_ЗДЕСЬ

# Имя отправителя (нужно согласовать с sms.ru → Мой аккаунт → Имена отправителей)
# Если не согласовано — оставьте пустым (будет показан номер)
SMSRU_FROM=Академия

# Тестовый режим: 1 = SMS не отправляются, деньги не списываются
# В ответе /request-code будет поле dev_code с кодом
SMSRU_TEST=1

# ─── Mattermost ──────────────────────────────────────
MM_SERVER_URL=http://localhost:8065

# Токен системного администратора (создаётся через bash sms_auth/setup.sh)
MM_ADMIN_TOKEN=

# ─── Параметры OTP ───────────────────────────────────
# Срок действия кода в минутах (по умолчанию 10)
OTP_TTL_MIN=10

# Максимум попыток ввода кода (по умолчанию 5)
MAX_ATTEMPTS=5

# Временный фиксированный код (только локальная разработка). SMS не шлётся. В production оставьте пустым!
OTP_DEV_CODE=1234

# ─── База данных ─────────────────────────────────────
SMS_DB_PATH=./sms_auth.db
